<project name="SotaPrograms" default="all_programs" basedir=".">

        <!-- ================== -->
        <!-- USER CONFIGURATION -->

        <!--ip -->
        <!--- For Sota -->
<!--        <property name="scp.server" value="10.151.63.71"/>-->
        <property name="scp.server" value="192.168.0.23"/>
         
        <!--scp credentials -->
        <property name="scp.edison.user" value="root"  />
        <property name="scp.edison.pass" value="edison00" />

        <!--target folders -->
        <property name="sota.basedir" value="/home/root/thinserver" />

        <!--dir structure -->
        <property name="src.dir" value="src"/>
        <property name="bin.dir" value="bin"/>
        <property name="lib.dir" value="lib"/>
        <property name="jars.dir" value="jars"/>
        <property name="resources.dir" value="resources"/>
        <property name="javadoc.dir" value="docs"/>
        
        <property name="remotelib.dir" value="/home/vstone/lib"/>

        <!--runnable classpath. Update if you need new libraries -->
        <property name="jar.classpath"
        	value=". /home/vstone/lib/commons-math3-3.6.1.jar /home/vstone/lib/jackson-annotations-2.10.5.jar /home/vstone/lib/jackson-core-2.10.5.jar /home/vstone/lib/jackson-databind-2.10.5.jar /home/vstone/lib/websocket-api-9.4.58.v20250814.jar /home/vstone/lib/jetty-io-9.4.58.v20250814.jar /home/vstone/lib/jetty-security-9.4.58.v20250814.jar /home/vstone/lib/jetty-http-9.4.58.v20250814.jar /home/vstone/lib/jetty-util-9.4.58.v20250814.jar /home/vstone/lib/websocket-common-9.4.58.v20250814.jar /home/vstone/lib/websocket-server-9.4.58.v20250814.jar /home/vstone/lib/websocket-servlet-9.4.58.v20250814.jar /home/vstone/lib/slf4j-api-1.7.36.jar /home/vstone/lib/slf4j-simple-1.7.36.jar /home/vstone/lib/javalin-3.13.13.jar /home/vstone/lib/javax.servlet-api-3.1.0.jar /home/vstone/lib/jetty-server-9.4.58.v20250814.jar /home/vstone/lib/jetty-servlet-9.4.58.v20250814.jar /home/vstone/lib/kotlin-stdlib-1.6.21.jar /home/vstone/lib/kotlin-stdlib-common-1.6.21.jar /home/vstone/lib/kotlin-stdlib-jdk8-1.6.21.jar /home/vstone/lib/commons-math3-3.6.1.jar /home/vstone/lib/sotalib.jar /home/vstone/lib/SRClientHelper.jar /home/vstone/lib/core-2.2.jar /home/vstone/lib/javase-2.2.jar  /home/vstone/lib/jna-4.1.0.jar /home/vstone/lib/gson-2.6.1.jar /usr/local/share/OpenCV/java/opencv-310.jar"/>

        <path id="build.lib">   <!-- include all jars in the listed lib dir into our classpath-->
                <fileset dir="${lib.dir}" includes="*.jar" />
        </path>

        <!-- Targets -->
        <target name="clean">
                <delete dir="${bin.dir}"/>
                <delete dir="${jars.dir}"/>
                <echo>delete complete!</echo>
        </target>

        <target name="clean-remote">
                <!-- make the folder if it doesn't exist -->
                <sshexec
                        host="${scp.server}"
                        username="${scp.edison.user}"
                        password="${scp.edison.pass}"
                        command="rm -rf ${sota.basedir}"
                        trust="true" />
                <echo>remote delete complete!</echo>
        </target>

        <target name="compile">
                <mkdir dir="${bin.dir}"/>
                <javac includeantruntime="false" classpathref="build.lib" srcdir="${src.dir}" destdir="${bin.dir}" encoding="utf-8" release="8" debug="true" bootclasspath="lib/rt.jar">
                        <compilerarg value="-Xlint:unchecked"/>  <!-- suppress warnings about deprecated java 8, seems to not work -->
                        <exclude name="old/**"/>
                </javac>
        </target>

        <!-- ============ -->
        <target name="__make_jar">  <!-- internal use -->
                <jar jarfile="${jars.dir}/${jar.name}" basedir="${bin.dir}">
                        <manifest>
                                <attribute name="Main-Class" value="${jar.class}"/>
                                <attribute name="Class-Path" value="${jar.classpath}"/>
                        </manifest>
                </jar>
        </target>

        <target name="make_jars" depends="compile">
                <antcall target="__make_jar">
                        <param name="jar.class" value="main.SotaSystemController" />
                        <param name="jar.name" value="SotaThinServer.jar" />
                </antcall>
                <antcall target="__make_jar">
                        <param name="jar.class" value="sota.supportPrograms.ServoRangeCalibrator" />
                        <param name="jar.name" value="ServoRangeCalibrator.jar" />
                </antcall>
                <antcall target="__make_jar">
                        <param name="jar.class" value="sota.supportPrograms.ServoAngleReader" />
                        <param name="jar.name" value="ServoAngleReader.jar" />
                </antcall>

                <antcall target="__make_jar">
                        <param name="jar.class" value="sota.supportPrograms.ServoFKTest" />
                        <param name="jar.name" value="ServoFKTest.jar" />
                </antcall>

                <antcall target="__make_jar">
                        <param name="jar.class" value="sota.supportPrograms.ServoIKTest" />
                        <param name="jar.name" value="ServoIKTest.jar" />
                </antcall>

                <antcall target="__make_jar">
                        <param name="jar.class" value="sota.supportPrograms.ServoRangeTest" />
                        <param name="jar.name" value="ServoRangeTest.jar" />
                </antcall>
<!--               <antcall target="__make_jar">-->
<!--                        <param name="jar.class" value="old.test.TestSotaDialogController" />-->
<!--                        <param name="jar.name" value="TestSotaDialogController.jar" />-->
<!--                </antcall>-->
<!--                <antcall target="__make_jar">-->
<!--                        <param name="jar.class" value="old.test.TestAudioStream" />-->
<!--                        <param name="jar.name" value="TestAudioStream.jar" />-->
<!--                </antcall>-->
        </target>

        <target name="upload_jars">
                <!-- make the folder if it doesn't exist -->
                <sshexec
                        host="${scp.server}"
                        username="${scp.edison.user}"
                        password="${scp.edison.pass}"
                        command="mkdir -p ${sota.basedir}/${jars.dir}"
                        trust="true" />
    
                <scp todir="${scp.edison.user}:${scp.edison.pass}@${scp.server}:${sota.basedir}/${jars.dir}" trust="yes" sftp="true" >       
                        <fileset dir="${jars.dir}"/>
                </scp>
        </target>

        <target name="upload_libs">
                <scp todir="${scp.edison.user}:${scp.edison.pass}@${scp.server}:${remotelib.dir}" trust="yes" sftp="true" verbose="true" >       
                        <fileset dir="${lib.dir}"/>
                </scp>
        </target>

        <target name="upload_resources_all">
                <!-- make the folder if it doesn't exist -->
                <sshexec
                        host="${scp.server}"
                        username="${scp.edison.user}"
                        password="${scp.edison.pass}"
                        command="mkdir -p ${sota.basedir}/${resources.dir}"
                        trust="true" />
    
                <scp todir="${scp.edison.user}:${scp.edison.pass}@${scp.server}:${sota.basedir}/${resources.dir}" trust="yes" sftp="true" verbose="true" >       
                        <fileset dir="${resources.dir}"/>
                </scp>
        </target>

        <target name="upload_resources_utterances">
                <!-- make the folder if it doesn't exist -->
                <sshexec
                        host="${scp.server}"
                        username="${scp.edison.user}"
                        password="${scp.edison.pass}"
                        command="mkdir -p ${sota.basedir}/${resources.dir}/utterances"
                        trust="true" />
    
                <scp todir="${scp.edison.user}:${scp.edison.pass}@${scp.server}:${sota.basedir}/${resources.dir}/utterances" trust="yes" sftp="true" verbose="true" >       
                        <fileset dir="${resources.dir}/utterances"/>
                </scp>
        </target>

        <target name="upload_resources_config">
                <!-- make the folder if it doesn't exist -->
                <sshexec
                        host="${scp.server}"
                        username="${scp.edison.user}"
                        password="${scp.edison.pass}"
                        command="mkdir -p ${sota.basedir}/${resources.dir}/config"
                        trust="true" />
    
                <scp todir="${scp.edison.user}:${scp.edison.pass}@${scp.server}:${sota.basedir}/${resources.dir}/config" trust="yes" sftp="true" verbose="true" >       
                        <fileset dir="${resources.dir}/config"/>
                </scp>
        </target> 

        <target name="compile_and_send_jars" depends="compile, make_jars, upload_jars" description="Compile all into Jars and upload">
        </target>
</project>